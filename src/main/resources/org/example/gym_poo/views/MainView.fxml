<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0"
            prefWidth="1600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.gym_poo.controllers.MainController"
            styleClass="root-pane">

   <children>

      <!-- Sidebar -->
      <AnchorPane prefWidth="220.0"
                  prefHeight="800.0"
                  styleClass="sidebar">

         <children>

            <Label layoutX="35.0"
                   layoutY="50.0"
                   text="GYM_POO"
                   styleClass="logo-label">

               <font>
                  <Font size="28.0"/>
               </font>

            </Label>

         </children>

      </AnchorPane>

      <!-- Título -->
      <Label layoutX="700.0"
             layoutY="60.0"
             text="Panel Administración"
             styleClass="title-label">

         <font>
            <Font size="42.0"/>
         </font>

      </Label>

      <!-- Columna Izquierda -->
      <VBox layoutX="320.0"
            layoutY="220.0"
            spacing="40.0">

         <children>

            <Button text="Ingresar Clientes"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#ingresarClientes"/>

            <Button text="Actualizar Clientes"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#actualizarClientes"/>

            <Button text="Eliminar Clientes"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#eliminarClientes"/>

            <Button text="Crear Reporte"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#generarReportes"/>

         </children>

      </VBox>

      <!-- Columna Derecha -->
      <VBox layoutX="980.0"
            layoutY="220.0"
            spacing="40.0">

         <children>

            <Button text="Ingresar Asistencia"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#asistencia"/>

            <Button text="Registrar Salida"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#salida"/>

            <Button text="Sistema de Puntos"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#sistemaPuntos"/>

            <Button text="Clases Grupales"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#clases"/>

            <Button text="Inventario Equipo"
                    prefWidth="280.0"
                    prefHeight="55.0"
                    styleClass="menu-button"
                    onAction="#equipo"/>

         </children>

      </VBox>

   </children>

</AnchorPane>