<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<AnchorPane prefHeight="800.0"
            prefWidth="1600.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.gym_poo.controllers.ClientesController">

   <children>

      <Label layoutX="250.0" layoutY="36.0" text="Ingresar Nuevo Cliente">
         <font>
            <Font size="22.0"/>
         </font>
      </Label>

      <!-- Nombre -->
      <Label layoutX="80.0" layoutY="80.0" text="Nombre"/>
      <TextField fx:id="txtNombre"
                 layoutX="80.0"
                 layoutY="105.0"
                 prefWidth="250.0"/>

      <!-- Teléfono -->
      <Label layoutX="80.0" layoutY="150.0" text="Teléfono"/>
      <TextField fx:id="txtTelefono"
                 layoutX="80.0"
                 layoutY="175.0"
                 prefWidth="250.0"/>

      <!-- Correo -->
      <Label layoutX="80.0" layoutY="220.0" text="Correo"/>
      <TextField fx:id="txtCorreo"
                 layoutX="80.0"
                 layoutY="245.0"
                 prefWidth="250.0"/>

      <!-- Membresía -->
      <Label layoutX="80.0" layoutY="290.0" text="Membresía"/>

      <SplitMenuButton fx:id="btnMembresia"
                       layoutX="80.0"
                       layoutY="315.0"
                       prefWidth="180.0"
                       text="--Ninguna--">

         <items>
            <MenuItem text="Basica" onAction="#seleccionarBasica"/>
            <MenuItem text="Plus" onAction="#seleccionarPlus"/>
            <MenuItem text="Premium" onAction="#seleccionarPremium"/>
         </items>

      </SplitMenuButton>

      <!-- Metodo de pago -->
      <Label layoutX="80.0" layoutY="370.0" text="Método de Pago"/>

      <SplitMenuButton fx:id="btnMetodoPago"
                       layoutX="80.0"
                       layoutY="395.0"
                       prefWidth="180.0"
                       text="--Ninguno--">

         <items>
            <MenuItem text="Efectivo" onAction="#seleccionarEfectivo"/>
            <MenuItem text="Tarjeta" onAction="#seleccionarTarjeta"/>
            <MenuItem text="Transferencia" onAction="#seleccionarTransferencia"/>
         </items>

      </SplitMenuButton>


      <!-- Botones -->
      <Button layoutX="80.0"
              layoutY="520.0"
              prefWidth="150.0"
              text="Registrar Cliente"
              onAction="#registrarCliente"/>

      <Button layoutX="250.0"
              layoutY="520.0"
              prefWidth="150.0"
              text="Limpiar"
              onAction="#limpiarFormulario"/>

      <Button layoutX="420.0"
              layoutY="520.0"
              prefWidth="150.0"
              text="Volver al Inicio"
              onAction="#volverMain"/>

   </children>
</AnchorPane>